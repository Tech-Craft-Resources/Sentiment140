# MLflow tracking server
# For local development: run `mlflow server --host 0.0.0.0 --port 5000`
# For EC2: replace with your EC2 public URL
MLFLOW_TRACKING_URI=http://localhost:5000

# Experiment name in MLflow
MLFLOW_EXPERIMENT_NAME=sentiment140

# Random seed for reproducibility
RANDOM_SEED=42

# MLflow run ID of the best model (REQUIRED for the API to start)
# Get this from the MLflow UI or experiment tracking
MLFLOW_BEST_RUN_ID=
